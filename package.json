{
	"name": "kyros-monorepo",
	"version": "0.0.0",
	"private": true,
	"engines": {
		"node": ">=18"
	},
	"workspaces": ["packages/core"],
	"license": "MIT",
	"author": {
		"email": "contato@gabrieljs.dev",
		"name": "Gabriel de Jesus Silva",
		"url": "https://gabrieljs.dev"
	},
	"scripts": {
		"typecheck": "tsc -p tsconfig.tests.json",
		"test": "vitest --run",
		"test:watch": "vitest",
		"pretest:coverage": "rimraf -g coverage",
		"test:coverage": "vitest --coverage --run",
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "biome check .",
		"format": "biome format --write .",
		"changeset": "changeset",
		"version": "changeset version",
		"publish": "changeset publish",
		"release": "turbo run build && changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "^2.29.5",
		"@types/node": "^20.14.11",
		"@vitest/coverage-v8": "^2.0.3",
		"rimraf": "^6.0.1",
		"turbo": "^1.13.4",
		"typescript": "^5.5.3",
		"vitest": "^2.0.3"
	}
}
