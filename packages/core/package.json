{
	"name": "@kyros/core",
	"version": "0.1.0",
	"description": "Function-based Dependency Injection core for TypeScript and pure JavaScript — no decorators, no reflection.",
	"keywords": [
		"dependency-injection",
		"di",
		"ioc",
		"inversion-of-control",
		"container",
		"modules",
		"typescript",
		"no-decorators",
		"nestjs-alternative"
	],
	"sideEffects": false,
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gabrieljsilva/kyros.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/gabrieljsilva/kyros/tree/master/packages/core#readme",
	"bugs": "https://github.com/gabrieljsilva/kyros/issues",
	"engines": {
		"node": ">=18"
	},
	"files": ["dist"],
	"author": {
		"email": "contato@gabrieljs.dev",
		"name": "Gabriel de Jesus Silva",
		"url": "https://gabrieljs.dev"
	},
	"scripts": {
		"prebuild": "rimraf -g dist",
		"build": "rollup -c"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^26.0.1",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^15.2.3",
		"@rollup/plugin-typescript": "^11.1.6",
		"@types/node": "^20.14.11",
		"rimraf": "^6.0.1",
		"rollup": "^4.19.0",
		"tslib": "^2.6.3",
		"typescript": "^5.5.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
